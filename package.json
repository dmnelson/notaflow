{
  "name": "notaflow",
  "version": "0.1.0",
  "description": "Local CLI for preparing Brazilian NFS-e draft artifacts.",
  "type": "module",
  "bin": {
    "notaflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "verify": "npm run check && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.1",
    "decimal.js": "^10.6.0",
    "nfse-js": "^0.3.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
